# ==============================================================================
# Slack Surface Snap-in — environment configuration template.
#
# Copy this file to `.env` for local development:
#     cp .env.example .env
# Then fill in / adjust the values. `.env` is gitignored — never commit secrets.
#
# In production, pass these to the snap-in runtime via the platform's secret
# manager / global_values, NOT a checked-in .env file.
#
# All values below are optional — the code ships with sensible defaults
# (see code/src/config/defaults.ts). Override only what your env needs.
# ==============================================================================

# ---- Logging --------------------------------------------------------------
# Allowed: error | warn | info | debug.  Default: info.
# Use `debug` when triaging incidents — never leave on in prod.
LOG_LEVEL=info

# ---- HTTP / Slack ---------------------------------------------------------
# Override only when running against a Slack-compatible mock during tests.
# SLACK_API_BASE=https://slack.com/api

# ---- Webhook lifecycle (DevRev) -------------------------------------------
# How long the snap-in waits for a freshly-created DevRev webhook to become
# active before giving up.  Default: 10000 ms.
# WEBHOOK_MAX_WAIT_MS=10000

# Interval between webhook-status polls during the wait.  Default: 500 ms.
# WEBHOOK_POLL_INTERVAL_MS=500

# ---- act-as token cache ---------------------------------------------------
# Minutes a cached impersonation token stays usable.  Default: 30.
# ACT_AS_TOKEN_TTL_MINUTES=30

# Refresh-margin (ms): treat a token as stale this far before its expiry.
# ACT_AS_TOKEN_REFRESH_MARGIN_MS=60000

# ---- Slack signature verification -----------------------------------------
# How far the X-Slack-Request-Timestamp header may drift from server time
# before the request is rejected as a possible replay.  Slack's own guidance
# is 5 minutes — change at your own risk.  Default: 300 seconds.
# SLACK_TIMESTAMP_SKEW_SECONDS=300

# ---- Session lifecycle ----------------------------------------------------
# Idle TTL (minutes) — session expires after this much inactivity unless the
# snap-in's global_values override it.  Default: 480 (8 hours).
# SESSION_IDLE_TIMEOUT_MINUTES=480

# Hard absolute lifetime (hours) regardless of activity.  Default: 24.
# SESSION_ABSOLUTE_TIMEOUT_HOURS=24

# ---- Block-Kit rendering caps ---------------------------------------------
# Slack rejects messages with more than 50 blocks; tighten if needed.
# BLOCK_KIT_MAX_BLOCKS=50

# Hard caps on individual block text fields (Block-Kit rejects oversize).
# BLOCK_KIT_SECTION_TEXT_LIMIT=3000
# BLOCK_KIT_HEADER_TEXT_LIMIT=150

# Cap on a single AI "thought" line so verbose plans don't break Slack.
# AI_THOUGHT_MAX_LENGTH=250
