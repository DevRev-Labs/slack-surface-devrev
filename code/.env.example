# ──────────────────────────────────────────────────────────────────────────────
# Slack Surface Snap-in — Environment Variables
#
# Copy this file to .env for local development.
# .env is git-ignored; NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Logging ──────────────────────────────────────────────────────────────────
# Minimum log level. Accepted values: debug | info | warn | error | silent
# Default: info
LOG_LEVEL=info

# ── Slack ─────────────────────────────────────────────────────────────────────
# Override the Slack Web API base URL (useful for mocking in integration tests).
# Default: https://slack.com/api
SLACK_API_BASE=https://slack.com/api

# ── DevRev ────────────────────────────────────────────────────────────────────
# Override the DevRev REST API base URL.
# Default: https://api.devrev.ai
DEVREV_API_BASE=https://api.devrev.ai

# Act-as (user impersonation) token cache TTL in minutes.
# Tokens are refreshed before expiry to avoid races.
# Default: 5 (tokens themselves expire in 6 minutes)
ACT_AS_TOKEN_TTL_MINUTES=5
