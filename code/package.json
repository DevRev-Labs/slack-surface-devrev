{
  "name": "slack-surface",
  "version": "1.0.0",
  "description": "DevRev snap-in that integrates Slack with DevRev AI Agents",
  "main": "./dist/index.js",
  "scripts": {
    "lint": "eslint --ignore-path .gitignore .",
    "lint:check": "eslint --ignore-path .gitignore --max-warnings=200 .",
    "lint:fix": "eslint --fix --ignore-path .gitignore .",
    "typecheck": "tsc --noEmit",
    "build": "rimraf ./dist && tsc && cp -r src/fixtures dist/",
    "build:watch": "tsc --watch",
    "prepackage": "npm run build",
    "package": "tar -cvzf build.tar.gz dist package.json package-lock.json .npmrc",
    "start": "ts-node src/main.ts",
    "start:watch": "nodemon src/main.ts",
    "start:production": "node dist/main.js",
    "test:server": "nodemon --watch src  --watch test test/main.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "7.27.1",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-typescript": "^7.18.6",
    "@jest/test-sequencer": "30.2.0",
    "@types/body-parser": "1.19.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.4.0",
    "@types/node": "24.13.2",
    "@types/yargs": "^17.0.24",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "babel-jest": "29.7.0",
    "body-parser": "^2.2.0",
    "dotenv": "17.4.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sort-keys-fix": "1.1.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "express": "^5.0.0",
    "jest": "^29.4.2",
    "nodemon": "3.1.9",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "typescript": "5.9.3",
    "yargs": "18.0.0"
  },
  "dependencies": {
    "@babel/runtime": "7.27.1",
    "@devrev/typescript-sdk": "1.1.77",
    "axios": "^1.13.4",
    "protobufjs": "^7.6.2"
  }
}
